//@version=6
indicator("EXP-006D Frozen Holdout Trades Visual Audit", overlay=true, max_lines_count=500, max_labels_count=500)

// Visual audit only. This script hardcodes frozen trades from holdout_trades_r5.csv.
// It does not search ENTRY_A, STOP_A, EXIT_R5, optimize, or create signals.
// Use on ADAUSDT 4H. Recommended TradingView ticker: BYBIT:ADAUSDT.P; fallback: BINANCE:ADAUSDT.
showLong = input.bool(true, "showLong")
showShort = input.bool(true, "showShort")
showEntries = input.bool(true, "showEntries")
showExits = input.bool(true, "showExits")
showStops = input.bool(true, "showStops")
showMFE = input.bool(true, "showMFE")
showMAE = input.bool(true, "showMAE")
showGiveback = input.bool(true, "showGiveback")
showEMAWarning = input.bool(true, "showEMAWarning")
showRegime = input.bool(true, "showRegime")
showLabels = input.bool(true, "showLabels")
showOnlyLosingTrades = input.bool(false, "showOnlyLosingTrades")
showOnlyWinningTrades = input.bool(false, "showOnlyWinningTrades")
tradeFrom = input.int(1, "tradeFrom", minval=1, maxval=31)
tradeTo = input.int(31, "tradeTo", minval=1, maxval=31)

ema27 = ta.ema(close, 27)
ema200 = ta.ema(close, 200)
plot(ema27, "EMA27", color=color.aqua, linewidth=2)
plot(ema200, "EMA200", color=color.orange, linewidth=2)

