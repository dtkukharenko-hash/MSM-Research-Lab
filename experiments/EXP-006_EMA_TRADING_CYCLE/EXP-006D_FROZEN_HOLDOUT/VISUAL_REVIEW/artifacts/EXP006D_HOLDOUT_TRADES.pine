var bool[] ambiguous = array.from(false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, false, false, false, false, false, false, false, false, false, false, false, false, false)

f_visible(int i) =>
    string dir = array.get(dirs, i)
    float pnl = array.get(pnlPct, i)
    int n = array.get(tradeNo, i)
    bool dirOk = (dir == "LONG" and showLong) or (dir == "SHORT" and showShort)
    bool rangeOk = n >= tradeFrom and n <= tradeTo
    bool pnlOk = (not showOnlyLosingTrades or pnl < 0) and (not showOnlyWinningTrades or pnl > 0)
    dirOk and rangeOk and pnlOk

f_dir_color(string dir, float pnl) =>
    dir == "LONG" ? (pnl >= 0 ? color.lime : color.green) : (pnl >= 0 ? color.red : color.maroon)

f_pct(float x) =>
    na(x) ? "na" : str.tostring(x, "#.##") + "%"

f_num(float x) =>
    na(x) ? "na" : str.tostring(x, "#.########")

f_style_for_exit(string reason) =>
    reason == "STOP_A" ? line.style_solid : reason == "EMA27_HYSTERESIS" ? line.style_dashed : line.style_dotted

if barstate.islast
    for i = 0 to array.size(tradeNo) - 1
        if f_visible(i)
            int n = array.get(tradeNo, i)
            string id = array.get(tradeIds, i)
            string dir = array.get(dirs, i)
            int et = array.get(entryTimes, i)
            int xt = array.get(exitTimes, i)
            int mt = array.get(mfeTimes, i)
            int at = array.get(maeTimes, i)
            float ep = array.get(entryPrices, i)
            float xp = array.get(exitPrices, i)
            float sp = array.get(stopPrices, i)
            float mp = array.get(mfePrices, i)
            float ap = array.get(maePrices, i)
            float gp = array.get(givebackPrices, i)
            float pnl = array.get(pnlPct, i)
            float mfe = array.get(mfeAtr, i)
            float mae = array.get(maeAtr, i)
            float cap = array.get(captures, i)
            int bars = array.get(barsHeld, i)
            string reason = array.get(exitReasons, i)
            string q = array.get(quarters, i)
            string fail = array.get(failureTypes, i)
            string tags = array.get(specialTags, i)
            bool amb = array.get(ambiguous, i)
            color c = f_dir_color(dir, pnl)
            color winLoss = pnl >= 0 ? color.new(color.lime, 0) : color.new(color.red, 0)

            line.new(et, ep, xt, xp, xloc=xloc.bar_time, color=color.new(c, 0), width=2)
            line.new(et, ep, xt, ep, xloc=xloc.bar_time, color=color.new(color.gray, 35), style=line.style_solid)
            if showStops
                line.new(et, sp, xt, sp, xloc=xloc.bar_time, color=color.new(color.red, 25), style=line.style_dotted, width=2)
            if showExits
                line.new(et, xp, xt, xp, xloc=xloc.bar_time, color=color.new(winLoss, 15), style=f_style_for_exit(reason), width=2)
            if showMFE
                line.new(et, mp, xt, mp, xloc=xloc.bar_time, color=color.new(color.lime, 35), style=line.style_dashed)
                label.new(mt, mp, "MFE T" + str.tostring(n) + " " + f_num(mfe) + " ATR", xloc=xloc.bar_time, style=label.style_label_down, color=color.new(color.lime, 20), textcolor=color.black, size=size.tiny)
            if showMAE
                line.new(et, ap, xt, ap, xloc=xloc.bar_time, color=color.new(color.red, 35), style=line.style_dashed)
                label.new(at, ap, "MAE T" + str.tostring(n) + " " + f_num(mae) + " ATR", xloc=xloc.bar_time, style=label.style_label_up, color=color.new(color.red, 20), textcolor=color.white, size=size.tiny)
            if showGiveback and not na(gp)
                line.new(et, gp, xt, gp, xloc=xloc.bar_time, color=color.new(color.yellow, 15), style=line.style_dotted, width=2)
                if mfe >= 1
                    label.new(mt, gp, "R5 active / 50% giveback", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.yellow, 10), textcolor=color.black, size=size.tiny)
            if showEntries
                label.new(et, ep, "T" + str.tostring(n, "00") + " " + dir + "
ENTRY
price=" + f_num(ep), xloc=xloc.bar_time, style=dir == "LONG" ? label.style_label_up : label.style_label_down, color=color.new(c, 0), textcolor=color.white, size=size.small)
            if showExits
                label.new(xt, xp, "T" + str.tostring(n, "00") + " EXIT
reason=" + reason + "
PnL=" + f_pct(pnl) + "
PF contrib=" + f_pct(pnl) + "
capture=" + f_num(cap) + "
bars=" + str.tostring(bars), xloc=xloc.bar_time, style=label.style_label_left, color=color.new(winLoss, 0), textcolor=color.white, size=size.small)
            if showEMAWarning and reason == "EMA27_HYSTERESIS"
                label.new(xt, xp, "EMA warning / hysteresis exit", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
            if showRegime and reason == "REGIME_FLIP"
                label.new(xt, xp, "REGIME FLIP", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.purple, 0), textcolor=color.white, size=size.tiny)
            if reason == "STOP_A"
                label.new(xt, sp, "STOP_A", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
            if amb
                label.new(xt, xp, "INTRABAR AMBIGUITY
STOP priority", xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
            if showLabels and tags != "none"
                label.new(xt, xp, tags, xloc=xloc.bar_time, style=label.style_label_right, color=color.new(color.blue, 15), textcolor=color.white, size=size.tiny)

// Groups: winners/losers by PnL label color; stop/giveback/EMA/regime by exit reason; ambiguity by magenta label; LONG/SHORT by entry label.
