var string[] exitReasons = array.from("STOP_A", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "EMA27_HYSTERESIS", "EMA27_HYSTERESIS", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "STOP_A", "STOP_A", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "STOP_A", "MFE_50_GIVEBACK", "MFE_50_GIVEBACK", "STOP_A")
