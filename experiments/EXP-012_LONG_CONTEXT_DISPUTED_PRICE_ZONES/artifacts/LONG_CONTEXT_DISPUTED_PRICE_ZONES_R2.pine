showEma27BandDepartureEvents = input.bool(false, "showEma27BandDepartureEvents")
selectedSection = input.string("ALL", "selectedSection", options=["ALL", "Z001", "Z002", "Z003", "Z004", "Z005", "Z006"])

var string[] pZoneIds = array.from("Z001", "Z002", "Z003", "Z004", "Z005", "Z006")
