//@version=6
indicator("EXP-005 Major Move Precursors", overlay=true, max_lines_count=200, max_labels_count=200)

// Retrospective visual research markup only. Not an auto-signal and not a strategy.
// Use on ADAUSDT 4H. Recommended TradingView ticker: BYBIT:ADAUSDT.P; fallback: BINANCE:ADAUSDT.
showLong = input.bool(true, "showLong")
showShort = input.bool(true, "showShort")
showPrecursorWindow = input.bool(true, "showPrecursorWindow")
showEMA27 = input.bool(true, "showEMA27")
showEMA200 = input.bool(true, "showEMA200")
showLabels = input.bool(true, "showLabels")

ema27 = ta.ema(close, 27)
ema200 = ta.ema(close, 200)
plot(showEMA27 ? ema27 : na, "EMA27", color=color.rgb(0, 140, 255), linewidth=2)
plot(showEMA200 ? ema200 : na, "EMA200", color=color.rgb(120, 120, 120), linewidth=2)

var int[] starts = array.from(timestamp("Etc/UTC", 2023, 9, 11, 16, 0), timestamp("Etc/UTC", 2023, 12, 13, 20, 0), timestamp("Etc/UTC", 2024, 1, 23, 8, 0), timestamp("Etc/UTC", 2024, 3, 14, 8, 0), timestamp("Etc/UTC", 2024, 7, 5, 0, 0), timestamp("Etc/UTC", 2024, 7, 16, 0, 0), timestamp("Etc/UTC", 2024, 8, 5, 8, 0), timestamp("Etc/UTC", 2024, 9, 6, 16, 0), timestamp("Etc/UTC", 2024, 10, 26, 12, 0), timestamp("Etc/UTC", 2024, 12, 3, 0, 0), timestamp("Etc/UTC", 2024, 12, 20, 8, 0), timestamp("Etc/UTC", 2025, 1, 17, 16, 0), timestamp("Etc/UTC", 2025, 2, 28, 4, 0), timestamp("Etc/UTC", 2025, 3, 2, 20, 0), timestamp("Etc/UTC", 2025, 4, 7, 4, 0), timestamp("Etc/UTC", 2025, 5, 10, 20, 0), timestamp("Etc/UTC", 2025, 6, 22, 12, 0), timestamp("Etc/UTC", 2025, 8, 2, 16, 0), timestamp("Etc/UTC", 2025, 9, 13, 8, 0), timestamp("Etc/UTC", 2025, 12, 31, 16, 0), timestamp("Etc/UTC", 2026, 1, 14, 0, 0))
var string[] ids = array.from("M01", "M02", "M03", "M04", "M05", "M06", "M07", "M08", "M09", "M10", "M11", "M12", "M13", "M14", "M15", "M16", "M17", "M18", "M19", "M20", "M21")
var string[] dirs = array.from("LONG", "SHORT", "LONG", "SHORT", "LONG", "SHORT", "LONG", "LONG", "LONG", "SHORT", "LONG", "SHORT", "LONG", "SHORT", "LONG", "SHORT", "LONG", "LONG", "SHORT", "LONG", "SHORT")

var color bg = na
bg := na

for i = 0 to array.size(starts) - 1
    int st = array.get(starts, i)
    string id = array.get(ids, i)
    string dir = array.get(dirs, i)
    bool visible = dir == "LONG" ? showLong : showShort
    color c = dir == "LONG" ? color.rgb(0, 170, 120) : color.rgb(210, 70, 70)
    int precursorStart = st - 30 * 4 * 60 * 60 * 1000
    if visible and showPrecursorWindow and time >= precursorStart and time < st
        bg := color.new(c, 90)
    if visible and time == st
        line.new(time, low, time, high, xloc=xloc.bar_time, extend=extend.both, color=c, width=2)
        if showLabels
            label.new(time, high, id + " " + dir, xloc=xloc.bar_time, style=label.style_label_down, color=color.new(c, 0), textcolor=color.white, size=size.small)

bgcolor(bg)
