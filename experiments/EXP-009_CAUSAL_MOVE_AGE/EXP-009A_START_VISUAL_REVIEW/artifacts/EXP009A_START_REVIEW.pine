f_detector_visible(string det) =>
    detectorMode == "ALL" or detectorMode == det

f_zone_short(string z) =>
    z == "ZONE_0_BEFORE_MOVE" ? "Z0_BEFORE" : z == "ZONE_1_BIRTH" ? "Z1_BIRTH" : z == "ZONE_2_FIRST_PULLBACK" ? "Z2_PULLBACK" : z == "ZONE_3_EARLY_CONTINUATION" ? "Z3_EARLY" : z == "ZONE_4_MATURE_MOVE" ? "Z4_MATURE" : z == "ZONE_5_LATE_MOVE" ? "Z5_LATE" : z == "ZONE_6_EXHAUSTION_OR_CHOP" ? "Z6_EXHAUSTION" : "OUTSIDE"

f_zone_color(string z) =>
    z == "ZONE_0_BEFORE_MOVE" ? color.new(color.gray, 92) : z == "ZONE_1_BIRTH" ? color.new(color.green, 88) : z == "ZONE_2_FIRST_PULLBACK" ? color.new(color.blue, 88) : z == "ZONE_3_EARLY_CONTINUATION" ? color.new(color.teal, 88) : z == "ZONE_4_MATURE_MOVE" ? color.new(color.yellow, 88) : z == "ZONE_5_LATE_MOVE" ? color.new(color.orange, 88) : color.new(color.red, 88)

f_start_color(string det) =>
    det == "START_A" ? color.yellow : det == "START_B" ? color.red : color.purple

int idx = moveNumber - 1
int refStart = array.get(moveStarts, idx)
int refEnd = array.get(moveEnds, idx)
float refStartPrice = array.get(moveStartPrices, idx)
int windowStart = refStart - 50 * BAR_MS
int windowEnd = refEnd + 30 * BAR_MS
bool inWindow = time >= windowStart and time <= windowEnd
bool drawHere = showOnlyWindow ? inWindow : true
int ageBars = int(math.round((time - refStart) / BAR_MS))

string currentZone = "OUTSIDE_REFERENCE"
for i = 0 to array.size(zoneMoveNos) - 1
    if array.get(zoneMoveNos, i) == moveNumber and time >= array.get(zoneStarts, i) and time <= array.get(zoneEnds, i)
        currentZone := array.get(zoneNames, i)

bool isPrimaryBar = time == array.get(primaryTimes, idx)
bool isSecondaryBar = time == array.get(secondaryTimes, idx)
bool isFocBar = false
bool isBlockedBar = false
bool isStartBar = false
for i = 0 to array.size(focMoveNos) - 1
    if array.get(focMoveNos, i) == moveNumber and time == array.get(focTimes, i)
        isFocBar := true
for i = 0 to array.size(blockMoveNos) - 1
    if array.get(blockMoveNos, i) == moveNumber and time == array.get(blockTimes, i)
        isBlockedBar := true
for i = 0 to array.size(startMoveNos) - 1
    string det = array.get(startDetectors, i)
    if array.get(startMoveNos, i) == moveNumber and f_detector_visible(det) and time == array.get(startTimes, i)
        isStartBar := true

color bg = na
if drawHere and inWindow and showZones
    bg := f_zone_color(currentZone)
if drawHere and inWindow and showFalseMoves and detectorMode != "NONE"
    for i = 0 to array.size(falseMoveNos) - 1
        string det = array.get(falseDetectors, i)
        if array.get(falseMoveNos, i) == moveNumber and f_detector_visible(det) and time >= array.get(falseStarts, i) and time <= array.get(falseEnds, i)
            bg := color.new(color.gray, 82)
bgcolor(bg)

if drawHere and showReferenceStartEnd and time == refStart
    line.new(time, low, time, high, xloc=xloc.bar_time, extend=extend.both, color=color.white, width=4)
    if showLabels
        label.new(time, high, array.get(moveIds, idx) + " REF START " + array.get(moveDirs, idx), xloc=xloc.bar_time, style=label.style_label_down, color=color.white, textcolor=color.black, size=size.tiny)
if drawHere and showReferenceStartEnd and time == refEnd
    line.new(time, low, time, high, xloc=xloc.bar_time, extend=extend.both, color=color.white, width=2, style=line.style_dotted)
    if showLabels
        label.new(time, low, array.get(moveIds, idx) + " REF END", xloc=xloc.bar_time, style=label.style_label_up, color=color.white, textcolor=color.black, size=size.tiny)

if drawHere and showPrimary and isPrimaryBar
    label.new(time, low, showLabels ? "PRIMARY_ENTRY" : "P", xloc=xloc.bar_time, style=label.style_label_up, color=color.green, textcolor=color.white, size=size.tiny)
if drawHere and showSecondary and isSecondaryBar
    label.new(time, high, showLabels ? "OPTIONAL_SECONDARY_ENTRY" : "S", xloc=xloc.bar_time, style=label.style_label_down, color=color.blue, textcolor=color.white, size=size.tiny)

if drawHere and showBlocked
    for i = 0 to array.size(blockMoveNos) - 1
        if array.get(blockMoveNos, i) == moveNumber and time == array.get(blockTimes, i)
            label.new(time, close, showLabels ? array.get(blockLabels, i) : "X", xloc=xloc.bar_time, style=label.style_xcross, color=color.red, textcolor=color.white, size=size.tiny)

if drawHere and showFirstObservableChange
    for i = 0 to array.size(focMoveNos) - 1
        if array.get(focMoveNos, i) == moveNumber and time == array.get(focTimes, i)
            line.new(time, low, time, high, xloc=xloc.bar_time, extend=extend.both, color=color.teal, width=3, style=line.style_dashed)
            label.new(time, high, showLabels ? array.get(focLabels, i) : "FOC", xloc=xloc.bar_time, style=label.style_label_down, color=color.teal, textcolor=color.white, size=size.small)

if drawHere and detectorMode != "NONE"
    for i = 0 to array.size(startMoveNos) - 1
        string det = array.get(startDetectors, i)
        if array.get(startMoveNos, i) == moveNumber and f_detector_visible(det) and time == array.get(startTimes, i)
            color c = f_start_color(det)
            line.new(time, low, time, high, xloc=xloc.bar_time, extend=extend.both, color=c, width=2)
            if showLabels
                label.new(time, high, array.get(startLabels, i), xloc=xloc.bar_time, style=label.style_label_down, color=c, textcolor=color.black, size=size.tiny)

if drawHere and showFalseMoves and detectorMode != "NONE"
    for i = 0 to array.size(falseMoveNos) - 1
        string det = array.get(falseDetectors, i)
        if array.get(falseMoveNos, i) == moveNumber and f_detector_visible(det) and time == array.get(falseStarts, i)
            label.new(time, low, showLabels ? array.get(falseLabels, i) : "FALSE", xloc=xloc.bar_time, style=label.style_label_up, color=color.gray, textcolor=color.white, size=size.tiny)

bool ageEvent = isPrimaryBar or isSecondaryBar or isFocBar or isBlockedBar or isStartBar
bool ageStep = ageBars >= 1 and ageBars % 5 == 0
if drawHere and showMoveAge and time >= refStart and time <= refEnd and (ageStep or ageEvent)
    float distAtr = na(atr14) or atr14 == 0.0 ? na : math.abs(close - refStartPrice) / atr14
    string ageText = "age=" + str.tostring(ageBars) + "\ndist=" + str.tostring(distAtr, "#.##") + " ATR\n" + f_zone_short(currentZone)
    label.new(time, close, ageText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.black, 15), textcolor=color.white, size=size.tiny)
