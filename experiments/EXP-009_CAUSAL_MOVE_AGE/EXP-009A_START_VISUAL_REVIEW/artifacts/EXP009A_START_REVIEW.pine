//@version=6
indicator("EXP-009A Start Review Interactive", overlay=true, max_lines_count=500, max_labels_count=500)

// Visual audit only. Not a strategy, not a backtest, not a new detector, and not a PnL tool.
moveNumber = input.int(1, "moveNumber", minval=1, maxval=12)
detectorMode = input.string("ALL", "detectorMode", options=["ALL", "START_A", "START_B", "START_C", "NONE"])
showEMA = input.bool(true, "showEMA")
showReferenceStartEnd = input.bool(true, "showReferenceStartEnd")
showPrimary = input.bool(true, "showPrimary")
showSecondary = input.bool(true, "showSecondary")
showBlocked = input.bool(true, "showBlocked")
showFirstObservableChange = input.bool(true, "showFirstObservableChange")
showFalseMoves = input.bool(true, "showFalseMoves")
showZones = input.bool(true, "showZones")
showMoveAge = input.bool(true, "showMoveAge")
showLabels = input.bool(true, "showLabels")
showOnlyWindow = input.bool(true, "showOnlyWindow")

int BAR_MS = 4 * 60 * 60 * 1000
ema27 = ta.ema(close, 27)
ema200 = ta.ema(close, 200)
atr14 = ta.atr(14)
plot(showEMA ? ema27 : na, "EMA27", color=color.aqua, linewidth=1)
plot(showEMA ? ema200 : na, "EMA200", color=color.orange, linewidth=1)

